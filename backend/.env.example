# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT
JWT_SECRET=sua-chave-secreta-aleatoria-longa-e-unica

# Server
PORT=3001
NODE_ENV=development

# Job de follow-up automático (lembretes/no-show via WhatsApp).
# Deixe "false" (ou omita) em dev local — envia mensagens reais aos pacientes.
# Defina "true" apenas no ambiente de produção (Render).
ENABLE_FOLLOWUP_JOB=false

# UAZAPI (WhatsApp)
UAZAPI_URL=https://sua-instancia.uazapi.com
UAZAPI_TOKEN=seu-token-uazapi

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GEMINI_API_KEY=AIza...

# Groq (transcrição de áudio do WhatsApp)
GROQ_API_KEY=gsk_...

# Meshy API (Studio 3D) — plano com acesso à API
MESHY_API_KEY=
